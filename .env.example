# DebtFlow Backend — Environment Variables
# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง

# Database (Railway จะให้ค่านี้อัตโนมัติ)
DATABASE_URL=postgresql://user:password@host:5432/debtflow

# JWT Secret — เปลี่ยนเป็น random string ยาวๆ
SECRET_KEY=your-super-secret-key-change-this-now

# Admin credentials (single user)
ADMIN_USERNAME=pong
ADMIN_PASSWORD=your-password-here
# หรือใช้ hashed password (แนะนำ):
# python -c "from passlib.context import CryptContext; print(CryptContext(['bcrypt']).hash('your-password'))"
# ADMIN_PASSWORD_HASH=$2b$12$...

# Frontend URL สำหรับ CORS
ALLOWED_ORIGINS=https://debtflow.vercel.app,http://localhost:5173
